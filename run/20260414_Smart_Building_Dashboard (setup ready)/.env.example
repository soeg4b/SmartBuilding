# =============================================================================
# Smart Building Dashboard — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application ---
NODE_ENV=development                     # development | production | test
PORT=5000                                # Backend API port
FRONTEND_URL=http://localhost:5001       # Frontend URL (for CORS)

# --- Database (PostgreSQL + TimescaleDB) ---
DATABASE_URL=postgresql://postgres:password@localhost:5500/smart_building?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:5600         # Redis connection URL

# --- JWT Authentication ---
JWT_SECRET=your-jwt-secret-min-32-chars-change-this
JWT_ACCESS_EXPIRY=15m                    # Access token TTL (15 minutes)
JWT_REFRESH_EXPIRY=7d                    # Refresh token TTL (7 days)

# --- MQTT Broker ---
MQTT_BROKER_URL=mqtt://localhost:5700    # MQTT broker connection URL
MQTT_CLIENT_ID=smart-building-backend    # MQTT client identifier
MQTT_USERNAME=                           # MQTT auth username (optional)
MQTT_PASSWORD=                           # MQTT auth password (optional)
MQTT_TOPIC_PREFIX=building/              # Base topic prefix for subscriptions

# --- Socket.IO ---
SOCKETIO_CORS_ORIGIN=http://localhost:5001  # Allowed WebSocket origins

# --- File Upload ---
UPLOAD_DIR=./uploads                     # Directory for uploaded floor plans
MAX_FILE_SIZE=10485760                   # Max upload size in bytes (10MB)

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000              # Rate limit window (15 minutes)
RATE_LIMIT_MAX_REQUESTS=100              # Max requests per window (general)
RATE_LIMIT_AUTH_MAX=5                    # Max auth attempts per window

# --- Logging ---
LOG_LEVEL=info                           # debug | info | warn | error
LOG_FORMAT=json                          # json | pretty

# --- Email (SMTP) — optional for MVP ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=smtp-password
# SMTP_FROM=Smart Building <noreply@example.com>
